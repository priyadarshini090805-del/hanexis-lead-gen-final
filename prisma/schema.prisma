// AI-Driven Social Media Lead Generation — Prisma schema
// Modules 1, 2, 3

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== AUTH (NextAuth + custom) =====

enum Role {
  ADMIN
  USER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String? // hashed; null if OAuth-only
  role          Role      @default(USER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts Account[]
  sessions Session[]
  leads    Lead[]
  messages AiMessage[]
  prompts  PromptTemplate[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ===== MODULE 2 — LEADS =====

enum LeadStatus {
  NEW
  CONTACTED
  RESPONDED
  CONVERTED
  ARCHIVED
}

enum LeadSource {
  MANUAL
  CSV
  LINKEDIN
  INSTAGRAM
}

model Lead {
  id           String     @id @default(cuid())
  ownerId      String
  fullName     String
  email        String?
  company      String?
  jobTitle     String?
  linkedinUrl  String?
  instagramUrl String?
  bio          String?
  status       LeadStatus @default(NEW)
  source       LeadSource @default(MANUAL)
  score        Int        @default(0) // 0-100 lead quality score
  notes        String?    @db.Text

  tags     LeadTag[]
  messages AiMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId, status])
  @@index([ownerId, source])
}

model LeadTag {
  id     String @id @default(cuid())
  leadId String
  label  String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([leadId, label])
}

// ===== MODULE 3 — AI PERSONALIZATION =====

enum MessageKind {
  CONNECTION
  FOLLOW_UP
  SALES_PITCH
  CUSTOM
}

model PromptTemplate {
  id        String      @id @default(cuid())
  ownerId   String
  name      String
  kind      MessageKind
  body      String      @db.Text
  isDefault Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  owner     User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

model AiMessage {
  id        String      @id @default(cuid())
  ownerId   String
  leadId    String?
  kind      MessageKind
  prompt    String      @db.Text
  output    String      @db.Text
  model     String      @default("mock-gpt")
  createdAt DateTime    @default(now())

  owner User  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  lead  Lead? @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([ownerId, kind])
}
